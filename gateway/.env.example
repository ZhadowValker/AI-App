# ── AI Provider Keys (stored server-side, not on device) ──────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# ── JWT secret for app ↔ gateway auth ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex-string

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ── CORS — add your mobile app's origin if using web ──────────
ALLOWED_ORIGINS=*
